# Copia este archivo a .env y rellena los valores. Nunca subas .env a Git (contiene secretos).
APP_SECRET_KEY=pon_aqui_un_secret_largo_y_unico
APP_URL=https://tu-dominio.com
# Admins fijos (siempre tienen acceso). El resto se gestiona desde Admin → Administradores.
ADMIN_EMAILS=jorge@dragonne.co
OPENAI_API_KEY=sk-proj-...
# gpt-4o = mejor para insights; gpt-4o-mini = más barato
OPENAI_MODEL=gpt-4o

# Email (para recuperar contraseña). Cualquier SMTP: Gmail, SendGrid, Resend, SES, etc.
# Si no configuras SMTP, el enlace de “recordar contraseña” se muestra en pantalla (el usuario debe usarlo desde la misma sesión).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=DRAGONNÉ <noreply@tu-dominio.com>

STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_MONTHLY_PRICE_ID=price_xxx
STRIPE_ANNUAL_PRICE_ID=price_xxx
STRIPE_PRO_PLUS_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
TRIAL_DAYS=0

# API pública: acceso solo con clave asignada desde Admin → Acceso API.
API_RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_PER_DAY=1000

# Subida de archivos: máximo MB por archivo (por defecto 50). Extensiones permitidas: .csv, .xlsx, .xls, .xlsm.
# MAX_UPLOAD_MB=50

# Consultoría (/consultoria): enlace para "Agendar Demo". Crear "Appointment schedule" en Google Calendar (hefzi@dragonne.co) y pegar la URL aquí. Si no se define, se usa mailto.
# CONSULTING_CALENDAR_URL=https://calendar.app.google/h4SKsVcUvTp3JpNM6
