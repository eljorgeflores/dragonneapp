{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RevenueReport",
  "type": "object",
  "required": [
    "cover",
    "executive_summary",
    "key_findings",
    "anomalies",
    "kpi_table",
    "strategic_recommendations",
    "plan_30_60_90",
    "additional_reports_needed",
    "next_steps"
  ],
  "properties": {
    "cover": {
      "type": "object",
      "required": [
        "hotel_name",
        "report_title",
        "period_label",
        "prepared_by",
        "report_date"
      ],
      "properties": {
        "hotel_name": { "type": "string" },
        "report_title": { "type": "string" },
        "period_label": { "type": "string" },
        "prepared_by": { "type": "string" },
        "report_date": { "type": "string" }
      }
    },
    "executive_summary": { "type": "string" },
    "key_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "impact",
          "diagnosis",
          "business_implication",
          "recommended_action"
        ],
        "properties": {
          "title": { "type": "string" },
          "impact": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "diagnosis": { "type": "string" },
          "business_implication": { "type": "string" },
          "recommended_action": { "type": "string" }
        }
      }
    },
    "anomalies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "severity",
          "what_happened",
          "why_it_matters",
          "recommended_action"
        ],
        "properties": {
          "title": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "what_happened": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "recommended_action": { "type": "string" }
        }
      }
    },
    "kpi_table": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["metric", "value", "executive_read", "attention_level"],
        "properties": {
          "metric": { "type": "string" },
          "value": { "type": "string" },
          "executive_read": { "type": "string" },
          "attention_level": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "strategic_recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "priority", "action", "expected_impact"],
        "properties": {
          "title": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "action": { "type": "string" },
          "expected_impact": { "type": "string" }
        }
      }
    },
    "plan_30_60_90": {
      "type": "object",
      "required": ["days_30", "days_60", "days_90"],
      "properties": {
        "days_30": { "type": "array", "items": { "type": "string" } },
        "days_60": { "type": "array", "items": { "type": "string" } },
        "days_90": { "type": "array", "items": { "type": "string" } }
      }
    },
    "additional_reports_needed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["report_name", "why_it_is_needed"],
        "properties": {
          "report_name": { "type": "string" },
          "why_it_is_needed": { "type": "string" }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
